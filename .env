# ── Flask / Backend ──────────────────────────────────────────────
# Generate a strong secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=007f78d34a958edac3a45a5ea5d7f7da1a7775eb8aa08fcb1d3e4173205e0d6d

# Set to "production" on your server; keeps debug off
FLASK_ENV=development


# ── Firebase CLIENT-SIDE config (safe to expose in HTML) ─────────
# These values appear in your Firebase console →
#   Project Settings → General → Your apps → Web app
FIREBASE_API_KEY=AIzaSyCHStoxGwV0-CFhncdu7qhk5MdFccExP9A
FIREBASE_AUTH_DOMAIN=kavachids.firebaseapp.com
FIREBASE_PROJECT_ID=kavachids
FIREBASE_STORAGE_BUCKET=kavachids.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=199672073712
FIREBASE_APP_ID=1:199672073712:web:59fe4971721c5d02526135
FIREBASE_MEASUREMENT_ID=G-832XRMYHJV


# ── Firebase ADMIN SDK (SERVER-SIDE only — keep secret!) ─────────
# Download the JSON key from Firebase console →
#   Project Settings → Service Accounts → Generate new private key
# Then either:
#   a) Point to the downloaded JSON file:
GOOGLE_APPLICATION_CREDENTIALS=./kavachids-firebase-adminsdk.json
#   b) Or paste individual fields from that JSON below:
FIREBASE_ADMIN_PROJECT_ID=kavachids
FIREBASE_ADMIN_PRIVATE_KEY_ID=replace_with_private_key_id_from_service_account_json
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nreplace_with_actual_key\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@kavachids.iam.gserviceaccount.com
FIREBASE_ADMIN_CLIENT_ID=replace_with_client_id
FIREBASE_ADMIN_TOKEN_URI=https://oauth2.googleapis.com/token


# ── GitHub OAuth App (if using GitHub OAuth on the server side) ──
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: https://yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=replace_with_github_oauth_client_id
GITHUB_CLIENT_SECRET=replace_with_github_oauth_client_secret


# ── Google OAuth (if using server-side OAuth in addition to Firebase) ──
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret


# ── Microsoft / Azure AD (if using server-side Microsoft OAuth) ──
# Register app at: https://portal.azure.com → Azure Active Directory → App registrations
MICROSOFT_CLIENT_ID=replace_with_azure_app_client_id
MICROSOFT_CLIENT_SECRET=replace_with_azure_app_client_secret
MICROSOFT_TENANT_ID=common


# ── Database ─────────────────────────────────────────────────────
# Examples — use whichever database you're running
DATABASE_URL=sqlite:///kavach.db
# DATABASE_URL=postgresql://user:password@localhost:5432/kavach_db
# DATABASE_URL=mysql+pymysql://user:password@localhost/kavach_db


# ── Email (for password-reset emails etc.) ───────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password   # use an App Password, not your real password
MAIL_DEFAULT_SENDER=KAVACH IDS <your_email@gmail.com>


# ── Session / Cookie ─────────────────────────────────────────────
SESSION_COOKIE_SECURE=true       # set to false during local HTTP development
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=2592000   # 30 days in seconds